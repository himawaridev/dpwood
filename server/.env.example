DB_NAME=test
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_SSL=true
PORT=5000
DB_RETRY_DELAY_MS=60000

# Docker compose local database defaults. Use strong private values in real environments.
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=dpwood_db

JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
REFRESH_TOKEN_PEPPER=your_refresh_token_hash_pepper

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="DPWOOD Store <your_email@gmail.com>"

# Recommended for Render production because outbound SMTP ports may be blocked.
RESEND_API_KEY=
# Verify dpwood.store in Resend before using this sender. onboarding@resend.dev
# can only send test messages to the Resend account owner's email address.
RESEND_FROM="DPWOOD Store <newsletter@dpwood.store>"

PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_SECRET=your_cloudinary_secret

GOOGLE_CLIENT_ID=your_google_client_id

CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
UPLOAD_MAX_BYTES=3145728
IMAGE_PROXY_MAX_BYTES=5242880
IMAGE_PROXY_TIMEOUT_MS=8000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
PEXELS_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
